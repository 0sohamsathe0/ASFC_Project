# =========================================
# ASFC - All Star Fencing Club
# MERN Project .gitignore
# =========================================


# -----------------------------------------
# Dependencies
# -----------------------------------------

node_modules/


# -----------------------------------------
# Environment Variables / Secrets
# -----------------------------------------

.env
.env.*
!.env.example


# -----------------------------------------
# Build Files
# -----------------------------------------

dist/
build/


# -----------------------------------------
# Logs
# -----------------------------------------

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# -----------------------------------------
# Frontend / Vite
# -----------------------------------------

.vite/


# -----------------------------------------
# Backend Uploads
# -----------------------------------------

uploads/


# -----------------------------------------
# Generated Certificate / Export Files
# -----------------------------------------

certificates/
exports/


# -----------------------------------------
# Test / Coverage
# -----------------------------------------

coverage/


# -----------------------------------------
# Temporary Files
# -----------------------------------------

tmp/
temp/


# -----------------------------------------
# Operating System Files
# -----------------------------------------

.DS_Store
Thumbs.db


# -----------------------------------------
# IDE / Editor Files
# -----------------------------------------

.vscode/
.idea/


# -----------------------------------------
# Debug Files
# -----------------------------------------

*.pid
*.seed
*.pid.lock


# -----------------------------------------
# Cache Files
# -----------------------------------------

.cache/
.parcel-cache/


# -----------------------------------------
# Local Database Files
# -----------------------------------------

*.sqlite
*.sqlite3# =========================================
